{
  "info": {
    "name": "API Escola - Professores e Disciplinas",
    "_postman_id": "escola-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Professores",
      "item": [
        {
          "name": "Listar Professores",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/professores"
          }
        },
        {
          "name": "Buscar Professor",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/professores/1"
          }
        },
        {
          "name": "Criar Professor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\": \"Jo\\u00e3o Silva\", \"email\": \"joao@email.com\"}"
            },
            "url": "{{baseUrl}}/professores"
          }
        },
        {
          "name": "Atualizar Professor",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\": \"Jo\\u00e3o Atualizado\", \"email\": \"joao.novo@email.com\"}"
            },
            "url": "{{baseUrl}}/professores/1"
          }
        },
        {
          "name": "Excluir Professor",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/professores/1"
          }
        }
      ]
    },
    {
      "name": "Disciplinas",
      "item": [
        {
          "name": "Listar Disciplinas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/disciplinas"
          }
        },
        {
          "name": "Buscar Disciplina",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/disciplinas/1"
          }
        },
        {
          "name": "Criar Disciplina",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\": \"Banco de Dados\", \"carga_horaria\": 80, \"professor_id\": 1}"
            },
            "url": "{{baseUrl}}/disciplinas"
          }
        },
        {
          "name": "Atualizar Disciplina",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nome\": \"Banco de Dados Avan\\u00e7ado\", \"carga_horaria\": 100, \"professor_id\": 1}"
            },
            "url": "{{baseUrl}}/disciplinas/1"
          }
        },
        {
          "name": "Excluir Disciplina",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/disciplinas/1"
          }
        }
      ]
    }
  ]
}